{
  "name": "hotbook",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/bireactive",
    "packages/d3",
    "packages/react-d3",
    "packages/layout",
    "packages/apitable",
    "apps/hotbook",
    "apps/docs",
    "apps/svelte-layerchart-spike",
    "apps/vanilla-bireactive-spike",
    "apps/vanilla-bireactive-layercharts-spike",
    "apps/pinch-test"
  ],
  "scripts": {
    "build": "bash scripts/build-site.sh",
    "build:hotbook": "npm run build -w packages/d3 && npm run build -w packages/react-d3 && npm run build -w apps/hotbook",
    "dev:docs": "npm run dev -w apps/docs",
    "dev:hotbook": "npm run dev -w apps/hotbook",
    "dev:vanilla-bireactive": "npm run dev -w apps/vanilla-bireactive-spike",
    "dev:vanilla-bireactive-layercharts": "npm run dev -w apps/vanilla-bireactive-layercharts-spike",
    "dev:layout": "npm run demo -w packages/layout",
    "dev": "concurrently -n hotbook,vanilla-bireactive-layercharts \"npm run dev -w apps/hotbook\" \"npm run dev -w apps/vanilla-bireactive-layercharts-spike\"",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0"
  },
  "dependencies": {
    "bireactive": "^0.3.5"
  }
}
