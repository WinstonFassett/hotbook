{
  "name": "vizform",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bash scripts/build-site.sh",
    "build:sliceboard": "npm run build -w packages/vizform-vanilla-d3 && npm run build -w packages/vizform-react-d3 && npm run build -w apps/sliceboard",
    "dev:docs": "npm run dev -w apps/docs",
    "dev:sliceboard": "npm run dev -w apps/sliceboard",
    "dev:vanilla-bireactive": "npm run dev -w apps/vanilla-bireactive-spike",
    "dev:vanilla-bireactive-layercharts": "npm run dev -w apps/vanilla-bireactive-layercharts-spike",
    "dev:vanilla-bireactive-native-layout": "npm run demo -w packages/vizform-layout",
    "dev": "concurrently -n sliceboard,vanilla-bireactive-layercharts \"npm run dev -w apps/sliceboard\" \"npm run dev -w apps/vanilla-bireactive-layercharts-spike\"",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0"
  },
  "dependencies": {
    "bireactive": "^0.3.5"
  }
}
