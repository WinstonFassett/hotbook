{
  "name": "hotbook",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bash scripts/build-site.sh",
    "build:hotbook": "npm run build -w packages/d3 && npm run build -w apps/hotbook",
    "dev:docs": "npm run dev -w apps/docs",
    "dev:hotbook": "npm run dev -w apps/hotbook",
    "dev:demos": "npm run dev -w apps/demos",
    "dev": "concurrently -n hotbook,demos \"npm run dev -w apps/hotbook\" \"npm run dev -w apps/demos\"",
    "postinstall": "patch-package && node scripts/patch-bireactive-package-json.js",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "knip": "^6.26.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@valibot/to-json-schema": "^1.7.1",
    "flipping": "^1.1.0",
    "valibot": "^1.4.2"
  }
}
