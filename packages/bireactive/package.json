{
  "name": "@hotbook/bireactive",
  "version": "0.1.0",
  "description": "hotbook bireactive — all fine-grained surfaces (charts + graphs + tables).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WinstonFassett/hotbook.git",
    "directory": "packages/bireactive"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/hotbook-charts.umd.cjs",
  "module": "./dist/hotbook-charts.js",
  "exports": {
    ".": {
      "node": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/hotbook-charts.js",
      "require": "./dist/hotbook-charts.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch"
  },
  "peerDependencies": {
    "bireactive": "^0.3.4"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-color": "^3.1.0",
    "d3-hierarchy": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-zoom": "^3.0.0"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.2",
    "@types/d3-axis": "^3.0.0",
    "@types/d3-color": "^3.1.3",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/d3-selection": "^3.0.0",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-zoom": "^3.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
