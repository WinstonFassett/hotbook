{
  "name": "@hotbook/d3",
  "version": "0.1.0",
  "description": "hotbook D3-direct — all D3-direct surfaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WinstonFassett/vizform.git",
    "directory": "packages/d3"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/hotbook-d3.umd.cjs",
  "module": "./dist/hotbook-d3.js",
  "exports": {
    ".": {
      "node": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/hotbook-d3.js",
      "require": "./dist/hotbook-d3.umd.cjs"
    },
    "./host/tile-binder": {
      "node": {
        "types": "./src/host/tile-binder.ts",
        "import": "./src/host/tile-binder.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/hotbook-d3.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hotbook/bireactive": "*",
    "@hotbook/core": "*",
    "bireactive": "^0.3.4",
    "d3-drag": "^3.0.0",
    "d3-ease": "^3.0.1",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-transition": "^3.0.1"
  },
  "devDependencies": {
    "@types/d3-drag": "^3.0.7",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-shape": "^3.1.6",
    "@types/d3-transition": "^3.0.9",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.10"
  }
}
