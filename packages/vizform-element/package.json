{
  "name": "@winstonfassett/vizform-element",
  "version": "0.1.0",
  "description": "vizform vanilla custom elements — framework-agnostic <vizform-viz> and <vizform-hviz> web components.",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/vizform-element.umd.cjs",
  "module": "./dist/vizform-element.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vizform-element.js",
      "require": "./dist/vizform-element.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@winstonfassett/vizform-core": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
