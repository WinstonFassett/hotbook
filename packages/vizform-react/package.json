{
  "name": "@winstonfassett/vizform-react",
  "version": "0.1.0",
  "description": "vizform React adapter — thin wrappers over vizform-core for use in React apps and APITable.",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/vizform-react.umd.cjs",
  "module": "./dist/vizform-react.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vizform-react.js",
      "require": "./dist/vizform-react.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "dependencies": {
    "@winstonfassett/vizform-core": "*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
