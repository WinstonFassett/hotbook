{
  "name": "@winstonfassett/vizform-vanilla-d3",
  "version": "0.1.0",
  "description": "vizform vanilla D3 \u2014 pure D3/TS visualization engine, no framework dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WinstonFassett/vizform.git",
    "directory": "packages/vizform-vanilla-d3"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/vizform-vanilla-d3.umd.cjs",
  "module": "./dist/vizform-vanilla-d3.js",
