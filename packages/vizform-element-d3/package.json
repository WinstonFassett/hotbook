{
  "name": "@winstonfassett/vizform-element-d3",
  "version": "0.1.0",
  "description": "vizform D3 custom elements \u2014 framework-agnostic <vizform-viz> and <vizform-hviz> web components backed by vizform-vanilla-d3.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WinstonFassett/vizform.git",
    "directory": "packages/vizform-element-d3"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/vizform-element-d3.umd.cjs",
  "module": "./dist/vizform-element-d3.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vizform-element-d3.js",
      "require": "./dist/vizform-element-d3.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@winstonfassett/vizform-vanilla-d3": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
