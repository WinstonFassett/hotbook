{
  "name": "alloc-viz-react",
  "version": "0.1.0",
  "description": "Allocation visualizer — treemap, radial, bands. Pure React + D3, no platform dependencies.",
  "type": "module",
  "main": "./dist/alloc-viz-react.umd.cjs",
  "module": "./dist/alloc-viz-react.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/alloc-viz-react.js",
      "require": "./dist/alloc-viz-react.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "dependencies": {
    "d3-drag": "^3.0.0",
    "d3-ease": "^3.0.1",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-transition": "^3.0.1"
  },
  "devDependencies": {
    "@types/d3-drag": "^3.0.7",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-shape": "^3.1.6",
    "@types/d3-transition": "^3.0.9",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
