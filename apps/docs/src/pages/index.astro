---
import '../style.css';
const title = 'hotbook';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
</head>
<body>
  <div id="app">
    <header>
      <h1>hotbook</h1>
      <p class="tagline">Charts and tables that stay in sync.</p>
    </header>

    <section class="intro">
      <h2>What is Hotbook?</h2>
      <p>Hotbook is a suite of tools for directly manipulating the data in charts and tables.</p>
    </section>

    <nav class="demo-nav">
      <h2>Demos</h2>
      <ul>
        <li><a href="/hotbook/">Hotbook</a> <span> app for creating "hot" data tools with powerful direct manipulation features.</span></li>
        <li><a href="/demos/">Demos</a> <span>All the chart and layout demos.</span></li>
      </ul>
    </nav>

    <footer>
      <a href="https://github.com/WinstonFassett/hotbook">GitHub</a>
    </footer>
  </div>
</body>
</html>
