---
import '../style.css';
const title = 'hotbook — Bidirectional Data Visualization';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
</head>
<body>
  <div id="app">
    <header>
      <h1>hotbook</h1>
      <p class="tagline">Bidirectional Data Visualization</p>
    </header>

    <section class="intro">
      <h2>What is hotbook?</h2>
      <p>
        hotbook enables bidirectional data binding between visualizations and data views.
        Drag a bar — see the table update. Edit a cell — see the chart move.
      </p>
    </section>

    <nav class="demo-nav">
      <h2>Demos</h2>
      <ul>
        <li><a href="/demos/"><strong>All demos</strong></a> — every chart, gantt, treetable, and layout demo on one page. Anchor to any section: <code>/demos/#gantt</code>, <code>/demos/#treetable</code>, <code>/demos/#layout-nested</code>, etc.</li>
        <li><a href="/demos/bidirectional/">Bidirectional binding</a> — chart ↔ table demos with live two-way binding.</li>
        <li><a href="/hotbook/">Hotbook sliceboard</a> — the full interactive app.</li>
      </ul>
    </nav>

    <footer>
      <a href="https://github.com/WinstonFassett/hotbook">GitHub</a>
    </footer>
  </div>
</body>
</html>
