---
import '../style.css';
const title = 'hotbook — Bidirectional Data Visualization';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
</head>
<body>
  <div id="app">
    <header>
      <h1>hotbook</h1>
      <p class="tagline">Bidirectional Data Visualization</p>
    </header>

    <section class="intro">
      <h2>What is hotbook?</h2>
      <p>
        hotbook enables bidirectional data binding between visualizations and data views.
        Drag a bar — see the table update. Edit a cell — see the chart move.
      </p>
    </section>

    <nav class="demo-nav">
      <h2>Demos</h2>
      <ul>
        <li><a href="/demos/bidirectional/">Bidirectional Demos</a> — Embedded chart ↔ table demos with live binding</li>
        <li><a href="/demos/layout/">Layout</a> — Bireactive 2D graph layout engine</li>
        <li><a href="/demos/hotbook/">Hotbook</a> — Interactive chart demos</li>
      </ul>
    </nav>

    <footer>
      <a href="https://github.com/WinstonFassett/hotbook">GitHub</a>
    </footer>
  </div>
</body>
</html>
