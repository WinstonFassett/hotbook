{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@bireactive": ["../../inspo/bireactive/src/index.ts"],
      "@bireactive/coll": ["../../inspo/bireactive/src/coll.ts"],
      "@bireactive/tree": ["../../inspo/bireactive/src/tree.ts"],
      "@bireactive/*": ["../../inspo/bireactive/src/*/index.ts"]
    }
  },
  "include": ["src"]
}
